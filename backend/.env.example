# AgentProbe v3 Configuration
# Copy this to .env and fill in values

# Database URL (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///./agentprobe_v3.db
# DATABASE_URL=postgresql://user:password@localhost:5432/agentprobe_v3

# Base URL of the backend (must be reachable by the agent)
BASE_URL=http://localhost:8000
# BASE_URL=https://agentprobe-v3.onrender.com

# Frontend URL (for CORS)
FRONTEND_URL=https://gghhxx11299.github.io
